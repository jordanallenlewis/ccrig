{
  "_comment": "Copy this to statusline.config.json in the same folder as statusline.js. Your overrides deep-merge over the built-in defaults, so you only need the keys you actually change. Easiest way to edit: `node statusline.js --config`. 256-color codes: https://www.ditig.com/256-colors-cheat-sheet",
  "mode": "normal",
  "order": ["profile", "update", "folder", "model", "downgrade", "effort", "flags", "context", "git", "agents", "caveman", "billing", "session", "weekly", "forecast", "resumeHint", "cost", "sessionName"],
  "show": {
    "profile": "auto",
    "folder": true,
    "model": true,
    "downgrade": true,
    "effort": true,
    "flags": true,
    "context": true,
    "agents": true,
    "git": true,
    "caveman": true,
    "billing": true,
    "session": true,
    "weekly": true,
    "forecast": true,
    "resumeHint": true,
    "cost": false,
    "sessionName": false
  },
  "thresholds": {
    "context": { "green": 50, "yellow": 70 },
    "usage": { "green": 50, "yellow": 80, "warn": 90, "critical": 98 }
  },
  "resetStyle": "clock",
  "resumeTickets": true,
  "_guardian": "The next block powers the guardian. keepWorking + autopilot need the hooks wired: node statusline.js --install-guardian (which sets keepWorking:true and autopilot:notify). Default autopilot is 'off' so a plain install never checkpoints or notifies.",
  "keepWorking": false,
  "autopilot": "off",
  "autopilotBuffer": 45,
  "autopilotWeekly": false,
  "autopilotFailover": false,
  "claudeBin": "claude",
  "forecast": true,
  "ledger": false,
  "downgradeAlert": true,
  "updateCheck": true,
  "gitCacheMs": 2500,
  "reserveCols": 1,
  "profileLabels": { ".claude": "work", ".claude-personal": "personal" },
  "color": {
    "dim": 245, "folder": 75, "model": 111, "effort": 179, "flag": 45, "caveman": 172,
    "green": 78, "yellow": 214, "red": 203, "sky": 75,
    "profileDefault": 39, "profilePersonal": 213
  }
}
